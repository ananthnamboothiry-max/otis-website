---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Otis Labs — Precision Livestock Intelligence",
  description = "Bridging agricultural heritage with modern data infrastructure to optimize herd metrics, maximize yield, and secure legacy operations.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Work+Sans:wght@300..700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-background text-on-background antialiased">
    <slot />

    <script is:inline>
      // Reveal sections on scroll. Respects prefers-reduced-motion via CSS.
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              io.unobserve(e.target);
            }
          }
        },
        { rootMargin: "0px 0px -10% 0px", threshold: 0.1 }
      );
      document
        .querySelectorAll(".scroll-fade")
        .forEach((el) => io.observe(el));

      // Subtle nav background once scrolled past the hero edge.
      const nav = document.querySelector("[data-nav]");
      const mirrors = document.querySelectorAll("[data-scrolled-mirror]");
      const setNavScrolled = () => {
        if (!nav) return;
        const scrolled = window.scrollY > 24;
        if (scrolled) {
          nav.setAttribute("data-scrolled", "true");
          mirrors.forEach((m) => m.setAttribute("data-scrolled", "true"));
        } else {
          nav.removeAttribute("data-scrolled");
          mirrors.forEach((m) => m.removeAttribute("data-scrolled"));
        }
      };
      setNavScrolled();
      window.addEventListener("scroll", setNavScrolled, { passive: true });
    </script>
  </body>
</html>
